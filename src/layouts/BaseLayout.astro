---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import JsonLd from "../components/seo/JsonLd.astro";
import "../styles/global.css";
import { localeMeta, defaultLocale, type Locale } from "../utils/i18n";
import { absoluteUrl } from "../utils/seo";

interface Props {
  locale: Locale;
  title: string;
  description: string;
  alternateUrls: Partial<Record<Locale, string>>;
  image?: string;
  ogType?: "website" | "article";
  structuredData?: object | object[];
  canonicalPath?: string;
}
const {
  locale,
  title,
  description,
  alternateUrls,
  image = "/og-default.png",
  ogType = "website",
  structuredData,
  canonicalPath,
} = Astro.props;

const meta = localeMeta[locale];
const canonicalUrl = absoluteUrl(canonicalPath ?? Astro.url.pathname);
const ogImageUrl = absoluteUrl(image);
const siteName = "GoingMorocco";
---

<!doctype html>
<html lang={meta.htmlLang} dir={meta.dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Site verification -->
    <meta name="google-site-verification" content="QgI0KNgHjj5d9nP4A3GGmCLZnXUy24OZ3kRYRbB2SwY" />
    <meta name="p:domain_verify" content="fdb9410f560c2210120d4e868446680a" />
    <meta name="msvalidate.01" content="3F1EEB7D3DF710D7891093EDCBAE7188" />
    <!-- Travelpayouts verification: add your token below when available -->
    <!-- <meta name="travelpayouts-domain-verification" content="REPLACE_WITH_YOUR_CODE" /> -->

    <!-- Stay22 affiliate (head) -->
    <script>
      (function (s, t, a, y, twenty, two) {
        s.Stay22 = s.Stay22 || {};
        s.Stay22.params = { lmaID: '6993fc334cae3b9e41874695' };
        twenty = t.createElement(a);
        two = t.getElementsByTagName(a)[0];
        twenty.async = 1;
        twenty.src = y;
        two.parentNode.insertBefore(twenty, two);
      })(window, document, 'script', 'https://scripts.stay22.com/letmeallez.js');
    </script>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang alternates -->
    {Object.entries(alternateUrls).map(([loc, url]) => (
      <link rel="alternate" hreflang={loc} href={absoluteUrl(url)} />
    ))}
    {alternateUrls[defaultLocale] && (
      <link rel="alternate" hreflang="x-default" href={absoluteUrl(alternateUrls[defaultLocale]!)} />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={locale === "ar" ? "ar_MA" : "en_US"} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {structuredData && <JsonLd data={structuredData} />}
  </head>
  <body class="flex min-h-screen flex-col font-body text-ink">
    <Header locale={locale} alternateUrls={alternateUrls} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />

    <!-- Travelpayouts affiliate tracker (body) -->
    <script data-noptimize="1" data-cfasync="false">
      (function () {
        var script = document.createElement("script");
        script.async = 1;
        script.src = 'https://emrld.cc/NDcyOTI3.js?t=472927';
        document.head.appendChild(script);
      })();
    </script>

    <!-- Layla AI Morocco Guide chatbot -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600&display=swap">
    <style>
      #lcb,#lcw,#lcw *{box-sizing:border-box;margin:0;padding:0;font-family:'Nunito',sans-serif}
      #lcb{position:fixed;bottom:24px;left:24px;width:60px;height:60px;border-radius:50%;background:#C1440E;box-shadow:0 4px 20px rgba(193,68,14,.45);display:flex;align-items:center;justify-content:center;cursor:pointer;z-index:9999;border:none;transition:transform .2s,box-shadow .2s}
      #lcb:hover{transform:scale(1.08)}
      #lcb::before{content:'';position:absolute;inset:-4px;border-radius:50%;border:2px solid rgba(193,68,14,.35);animation:lcpulse 2.5s ease-out infinite}
      @keyframes lcpulse{0%{transform:scale(1);opacity:1}70%,100%{transform:scale(1.35);opacity:0}}
      #lcb svg{width:28px;height:28px;fill:#fff}
      #lcb .ic{display:none}
      #lcb.open .io{display:none}
      #lcb.open .ic{display:block}
      #lbadge{position:absolute;top:-2px;right:-2px;width:18px;height:18px;background:#E8B84B;border-radius:50%;font-size:10px;font-weight:600;color:#fff;display:flex;align-items:center;justify-content:center;border:2px solid #fff}
      #lcw{position:fixed;bottom:96px;left:24px;width:360px;height:550px;border-radius:20px;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 12px 48px rgba(0,0,0,.18);z-index:9998;background:#f7f4f0;transform:scale(.92) translateY(16px);opacity:0;pointer-events:none;transition:transform .25s cubic-bezier(.34,1.56,.64,1),opacity .2s}
      #lcw.open{transform:scale(1) translateY(0);opacity:1;pointer-events:all}
      #lch{background:#C1440E;padding:13px 16px;display:flex;align-items:center;gap:10px;flex-shrink:0}
      .lav{width:38px;height:38px;border-radius:50%;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:19px;flex-shrink:0}
      .lhn{font-weight:600;font-size:14px;color:#fff}
      .lhs{font-size:11px;color:rgba(255,255,255,.8);display:flex;align-items:center;gap:4px;margin-top:2px}
      .lsd{width:7px;height:7px;border-radius:50%;background:#6FE8B0}
      #lcls{margin-left:auto;background:none;border:none;color:rgba(255,255,255,.8);cursor:pointer;font-size:21px;line-height:1}
      #lms{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:10px;scroll-behavior:smooth}
      #lms::-webkit-scrollbar{width:4px}
      #lms::-webkit-scrollbar-thumb{background:rgba(0,0,0,.12);border-radius:4px}
      .lm{display:flex;gap:7px;align-items:flex-end;max-width:90%;animation:lfadeup .22s ease}
      @keyframes lfadeup{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
      .lm.u{flex-direction:row-reverse;align-self:flex-end}
      .lm.b{align-self:flex-start}
      .lma{width:28px;height:28px;border-radius:50%;background:#C1440E;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0}
      .lb{padding:10px 13px;font-size:14px;line-height:1.6;border-radius:18px}
      .lm.b .lb{background:#fff;color:#2d2018;border-bottom-left-radius:4px;box-shadow:0 1px 4px rgba(0,0,0,.07)}
      .lm.u .lb{background:#C1440E;color:#fff;border-bottom-right-radius:4px}
      .ltd{display:flex;gap:4px;align-items:center;padding:4px 2px}
      .ltd span{width:7px;height:7px;border-radius:50%;background:#bbb;animation:lblink 1.3s infinite}
      .ltd span:nth-child(2){animation-delay:.2s}
      .ltd span:nth-child(3){animation-delay:.4s}
      @keyframes lblink{0%,60%,100%{transform:translateY(0);background:#bbb}30%{transform:translateY(-5px);background:#C1440E}}
      .lac{margin-top:9px;border:1px solid #ede8e2;border-radius:11px;overflow:hidden;background:#fdf9f6}
      .lach{padding:5px 11px;font-size:10px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:#9a7a62;background:#f5ede4;border-bottom:1px solid #ede8e2}
      .lal{display:flex;align-items:center;gap:8px;padding:8px 11px;font-size:13px;font-weight:600;color:#C1440E;text-decoration:none;border-bottom:1px solid #ede8e2;transition:background .15s}
      .lal:last-child{border-bottom:none}
      .lal:hover{background:#fef3ec}
      .lai{font-size:14px;flex-shrink:0}
      .laa{margin-left:auto;font-size:12px;color:#c1946e}
      .lsug{display:flex;flex-wrap:wrap;gap:5px;margin-top:9px}
      .lchip{padding:5px 11px;border:1.5px solid #C1440E;border-radius:20px;font-size:12px;font-weight:600;color:#C1440E;background:transparent;cursor:pointer;transition:background .15s,color .15s}
      .lchip:hover{background:#C1440E;color:#fff}
      #lia{display:flex;gap:8px;padding:11px 13px;border-top:1px solid #ede8e2;background:#fff;flex-shrink:0}
      #lui{flex:1;border:1.5px solid #e4d8cc;border-radius:22px;padding:8px 15px;font-size:14px;outline:none;background:#fdf9f6;color:#2d2018;transition:border-color .2s}
      #lui:focus{border-color:#C1440E}
      #lui::placeholder{color:#b8a898}
      #lsb{width:38px;height:38px;border-radius:50%;background:#C1440E;border:none;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;color:#fff;font-size:16px;transition:background .2s}
      #lsb:hover{background:#a33a0c}
      #lsb:disabled{background:#e0cfc7;cursor:not-allowed}
      #lft{text-align:center;font-size:10px;color:#c1b0a0;padding:4px 0 7px;background:#fff;flex-shrink:0}
      #lft a{color:#C1440E;text-decoration:none}
      @media(max-width:420px){#lcw{width:calc(100vw - 16px);left:8px;bottom:78px}#lcb{left:16px;bottom:16px}}
    </style>

    <button id="lcb" aria-label="Chat with Morocco guide">
      <span id="lbadge">1</span>
      <svg class="io" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.163 2 11.243c0 2.821 1.33 5.338 3.42 7.036L4.5 22l4.08-2.04A10.94 10.94 0 0012 20.486c5.523 0 10-4.163 10-9.243C22 6.163 17.523 2 12 2z"/></svg>
      <svg class="ic" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12" stroke="#fff" stroke-width="2.5" stroke-linecap="round" fill="none"/></svg>
    </button>

    <div id="lcw" role="dialog">
      <div id="lch">
        <div class="lav">🕌</div>
        <div><div class="lhn">Layla — Morocco Guide</div><div class="lhs"><span class="lsd"></span> Online now</div></div>
        <button id="lcls">✕</button>
      </div>
      <div id="lms"></div>
      <div id="lia">
        <input id="lui" type="text" placeholder="Ask me anything about Morocco…" autocomplete="off"/>
        <button id="lsb">&#10148;</button>
      </div>
      <div id="lft">Powered by AI &nbsp;·&nbsp; <a href="https://goingmorocco.com" target="_blank">goingmorocco.com</a></div>
    </div>

    <script>
    (function(){
    const KEY='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',MODEL='llama-3.3-70b-versatile';
    const SYS=`You are Layla, a warm and knowledgeable Morocco travel guide for goingmorocco.com. Your visitors are mainly first-time tourists and luxury travelers. Be friendly, practical, and inspiring.

    ## CITIES
    Marrakech: Jemaa el-Fna square, souks, Bahia Palace, Majorelle Garden. Luxury riads: El Fenn, La Mamounia.
    Fes: Most authentic medieval city. Chouara tannery, Al-Qarawiyyin mosque. Always hire a licensed guide. Luxury: Riad Fes.
    Chefchaouen: The blue city in the Rif Mountains. Photography, hiking, relaxed vibe. Best as 2-night stop.
    Casablanca: Hassan II Mosque (on the ocean), the Corniche, great seafood.
    Essaouira: Atlantic coastal town. Kitesurfing, fresh fish, argan oil. Easy overnight from Marrakech.
    Merzouga/Sahara: Erg Chebbi dunes. Overnight camel trek + luxury desert camp under the stars.
    Ouarzazate: "Door to the desert." Ait Benhaddou UNESCO kasbah (filmed in Game of Thrones).

    ## ITINERARIES
    7 days (classic): Marrakech (3) → Fes via Ifrane (2) → Chefchaouen (2)
    10 days (best first-timer): Marrakech (3) → Sahara via Ouarzazate (3) → Fes (2) → Chefchaouen (2)
    14 days (luxury): Marrakech (3) → Essaouira (2) → Sahara (3) → Fes (3) → Chefchaouen (2) → Tangier (1)
    Best time to visit: March–May and September–November. Avoid July–August (extreme heat inland).

    ## AFFILIATES — suggest only relevant ones, max 3 per card:
    eSIMs: 📱 Yesim|https://yesim.tpk.ro/DI2I8GaE, 📱 Saily|https://saily.tpk.ro/wr6vLhwy, 📱 Airalo|https://airalo.tpk.ro/WdtAIt5E
    Hotels: 🏨 Booking.com|https://booking.tpk.ro/TPo7yE82, 🏨 Tripadvisor|https://tripadvisor.tpk.ro/1xWJjZDI, 🏨 Agoda|https://agoda.tpk.ro/u15zvirh
    Tours: 🧭 GetYourGuide|https://getyourguide.tpk.ro/OEokX3k4, 🧭 Viator|https://viator.tpk.ro/wV1ah8Ra
    Insurance: 🛡️ Insubuy|https://insubuy.tpk.ro/tcAWtbmO, 🛡️ VisitorsCoverage|https://visitorscoverage.tpk.ro/mNW2rGQj, ✈️ AirHelp|https://airhelp.tpk.ro/Mr4B8uyB
    Flights: ✈️ Omio|https://omio.tpk.ro/lWNFHv9H, ✈️ Expedia|https://expedia.tpk.ro/XBrW7f6f
    Airport Transfers: 🚐 GetTransfer|https://gettransfer.tpk.ro/XWrdiGm7, 🚐 Welcome Pickups|https://tpk.ro/eRCyStOi
    Car Rentals: 🚗 EconomyBookings|https://economybookings.tpk.ro/f6UbX8n0, 🚗 DiscoverCars|https://discovercars.tpk.ro/FpPHIJ3m

    When helpful, end your message with:
    [AC]
    title: Book it here
    links:
    - icon: ✈️ | label: Search on Omio | url: https://omio.tpk.ro/lWNFHv9H
    [/AC]

    Only show card for actionable requests. Max 3 links. Be warm, concise (2-4 paragraphs).`;

    const bubble=document.getElementById('lcb'),win=document.getElementById('lcw'),cls=document.getElementById('lcls'),badge=document.getElementById('lbadge'),msgs=document.getElementById('lms'),inp=document.getElementById('lui'),snd=document.getElementById('lsb');
    let hist=[],open=false;

    function toggle(){open?close():openChat()}
    function openChat(){open=true;win.classList.add('open');bubble.classList.add('open');badge.style.display='none';inp.focus()}
    function close(){open=false;win.classList.remove('open');bubble.classList.remove('open')}
    bubble.addEventListener('click',toggle);
    cls.addEventListener('click',close);

    function parseCard(t){
      const m=t.match(/\[AC\]([\s\S]*?)\[\/AC\]/);
      if(!m)return{text:t.trim(),card:null};
      const b=m[1],tm=b.match(/title:\s*(.+)/),title=tm?tm[1].trim():'Resources';
      const lms=[...b.matchAll(/- icon:\s*(.+?)\s*\|\s*label:\s*(.+?)\s*\|\s*url:\s*(.+)/g)];
      const links=lms.map(x=>({icon:x[1].trim(),label:x[2].trim(),url:x[3].trim()}));
      return{text:t.replace(/\[AC\][\s\S]*?\[\/AC\]/,'').trim(),card:links.length?{title,links}:null};
    }

    function renderCard(c){
      let h=`<div class="lac"><div class="lach">${c.title}</div>`;
      c.links.forEach(l=>{h+=`<a class="lal" href="${l.url}" target="_blank"><span class="lai">${l.icon}</span>${l.label}<span class="laa">↗</span></a>`});
      return h+'</div>';
    }

    function addMsg(role,raw,parsed){
      const w=document.createElement('div');w.className='lm '+role;
      if(role==='b'){const a=document.createElement('div');a.className='lma';a.textContent='🕌';w.appendChild(a)}
      const b=document.createElement('div');b.className='lb';
      if(parsed){b.innerHTML=parsed.text.replace(/\n/g,'<br>');if(parsed.card)b.innerHTML+=renderCard(parsed.card)}
      else b.textContent=raw;
      w.appendChild(b);msgs.appendChild(w);msgs.scrollTop=msgs.scrollHeight;
    }

    function addChips(items){
      const w=document.createElement('div');w.className='lsug';
      items.forEach(s=>{const b=document.createElement('button');b.className='lchip';b.textContent=s;b.onclick=()=>{w.remove();send(s)};w.appendChild(b)});
      const last=msgs.querySelector('.lm.b:last-child .lb');if(last)last.appendChild(w);
      msgs.scrollTop=msgs.scrollHeight;
    }

    function showTyping(){
      const w=document.createElement('div');w.className='lm b';w.id='ltyp';
      const a=document.createElement('div');a.className='lma';a.textContent='🕌';
      const b=document.createElement('div');b.className='lb';b.innerHTML='<div class="ltd"><span></span><span></span><span></span></div>';
      w.appendChild(a);w.appendChild(b);msgs.appendChild(w);msgs.scrollTop=msgs.scrollHeight;
    }

    async function send(text){
      if(!text.trim())return;
      addMsg('u',text,null);hist.push({role:'user',content:text});
      inp.value='';inp.disabled=true;snd.disabled=true;showTyping();
      try{
        const r=await fetch('https://api.groq.com/openai/v1/chat/completions',{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+KEY},body:JSON.stringify({model:MODEL,max_tokens:1000,messages:[{role:'system',content:SYS},...hist]})});
        const d=await r.json();
        if(!r.ok)throw new Error(d?.error?.message||'HTTP '+r.status);
        const raw=d.choices?.[0]?.message?.content||"Sorry, try again!";
        hist.push({role:'assistant',content:raw});
        document.getElementById('ltyp')?.remove();
        addMsg('b','',parseCard(raw));
      }catch(e){
        document.getElementById('ltyp')?.remove();
        addMsg('b','Something went wrong: '+e.message,null);
      }finally{inp.disabled=false;snd.disabled=false;inp.focus()}
    }

    snd.addEventListener('click',()=>send(inp.value));
    inp.addEventListener('keydown',e=>{if(e.key==='Enter')send(inp.value)});

    setTimeout(()=>{
      addMsg('b','',{text:"Marhaba! 👋 I'm Layla, your Morocco travel guide!\n\nPlanning a trip or just curious? I'm here to help with anything — flights, hotels, tours, or local tips. What can I do for you?",card:null});
      setTimeout(()=>addChips(['Book a hotel 🏨','Find flights ✈️','Tours & activities 🧭','Airport transfer 🚐','Travel insurance 🛡️']),350);
    },800);
    })();
    </script>
  </body>
</html>
