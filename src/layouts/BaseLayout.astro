---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import JsonLd from "../components/seo/JsonLd.astro";
import "../styles/global.css";
import { localeMeta, defaultLocale, type Locale } from "../utils/i18n";
import { absoluteUrl } from "../utils/seo";

interface Props {
  locale: Locale;
  title: string;
  description: string;
  alternateUrls: Partial<Record<Locale, string>>;
  image?: string;
  ogType?: "website" | "article";
  structuredData?: object | object[];
  canonicalPath?: string;
}
const {
  locale,
  title,
  description,
  alternateUrls,
  image = "/og-default.png",
  ogType = "website",
  structuredData,
  canonicalPath,
} = Astro.props;

const meta = localeMeta[locale];
const canonicalUrl = absoluteUrl(canonicalPath ?? Astro.url.pathname);
const ogImageUrl = absoluteUrl(image);
const siteName = "GoingMorocco";
---

<!doctype html>
<html lang={meta.htmlLang} dir={meta.dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="icon" href="/android-chrome-192x192.png" type="image/png" sizes="192x192" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Site verification -->
    <meta name="google-site-verification" content="QgI0KNgHjj5d9nP4A3GGmCLZnXUy24OZ3kRYRbB2SwY" />
    <meta name="p:domain_verify" content="fdb9410f560c2210120d4e868446680a" />
    <meta name="msvalidate.01" content="3F1EEB7D3DF710D7891093EDCBAE7188" />
    <!-- Travelpayouts verification: add your token below when available -->
    <!-- <meta name="travelpayouts-domain-verification" content="REPLACE_WITH_YOUR_CODE" /> -->

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang alternates -->
    {Object.entries(alternateUrls).map(([loc, url]) => (
      <link rel="alternate" hreflang={loc} href={absoluteUrl(url)} />
    ))}
    {alternateUrls[defaultLocale] && (
      <link rel="alternate" hreflang="x-default" href={absoluteUrl(alternateUrls[defaultLocale]!)} />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={locale === "ar" ? "ar_MA" : "en_US"} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {structuredData && <JsonLd data={structuredData} />}
  </head>
  <body class="flex min-h-screen flex-col font-body text-ink">
    <Header locale={locale} alternateUrls={alternateUrls} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />

    <!-- Stay22 affiliate widget bootstrap -->
    <script>
      (function (s, t, a, y, twenty, two) {
        s.Stay22 = s.Stay22 || {};
        s.Stay22.params = { lmaID: '6993fc334cae3b9e41874695' };
        twenty = t.createElement(a);
        two = t.getElementsByTagName(a)[0];
        twenty.async = 1;
        twenty.src = y;
        two.parentNode.insertBefore(twenty, two);
      })(window, document, 'script', 'https://scripts.stay22.com/letmeallez.js');
    </script>

    <!-- Travelpayouts affiliate tracker (body) -->
    <script data-noptimize="1" data-cfasync="false">
      (function () {
        var script = document.createElement("script");
        script.async = 1;
        script.src = 'https://emrld.cc/NDcyOTI3.js?t=472927';
        document.head.appendChild(script);
      })();
    </script>

  </body>
</html>
