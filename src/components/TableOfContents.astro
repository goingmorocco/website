---
import { t, type Locale } from "../utils/i18n";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
  locale: Locale;
}
const { headings, locale } = Astro.props;
const strings = t(locale);
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  items.length > 0 && (
    <nav aria-label={strings.blog.tableOfContents} class="rounded-xl border border-sand-light bg-sand-light/30 p-5">
      <p class="font-display text-sm font-semibold text-ink">{strings.blog.tableOfContents}</p>
      <ul class="mt-3 space-y-2 text-sm">
        {items.map((h) => (
          <li class:list={[h.depth === 3 && "ps-4"]}>
            <a href={`#${h.slug}`} class="text-ink/70 hover:text-royal">
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
