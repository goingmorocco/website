---
import PostCard from "./PostCard.astro";
import { t, type Locale } from "../utils/i18n";
import type { CollectionEntry } from "astro:content";

interface Props {
  locale: Locale;
  posts: CollectionEntry<"blog">[];
  categoryName?: (id: string) => string | undefined;
}
const { locale, posts, categoryName } = Astro.props;
const strings = t(locale);
---

{
  posts.length > 0 && (
    <section class="border-t border-sand-light pt-8" aria-labelledby="related-heading">
      <h2 id="related-heading" class="font-display text-xl text-ink">
        {strings.blog.relatedArticles}
      </h2>
      <div class="mt-5 grid gap-6 sm:grid-cols-3">
        {posts.map((post) => (
          <PostCard post={post} categoryName={categoryName?.(post.data.category)} />
        ))}
      </div>
    </section>
  )
}
