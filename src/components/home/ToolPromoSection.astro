---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  ctaText: string;
  ctaHref: string;
  image: string;
  imageAlt: string;
  /** Alternate image/text side so two promo sections in a row don't look identical. */
  reverse?: boolean;
}

const { eyebrow, title, description, ctaText, ctaHref, image, imageAlt, reverse = false } = Astro.props;
---

<section class="border-b border-sand-light bg-sand-light/30 py-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class:list={["grid items-center gap-10 lg:grid-cols-2", reverse && "lg:[&>*:first-child]:order-2"]}>
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-royal">{eyebrow}</p>
        <h2 class="mt-2 font-display text-2xl text-ink sm:text-3xl">{title}</h2>
        <p class="mt-4 text-ink/70">{description}</p>
        <a
          href={ctaHref}
          target="_blank"
          rel="noopener"
          class="mt-6 inline-flex items-center justify-center rounded-full bg-royal px-6 py-3 font-semibold text-white shadow-sm transition-transform hover:scale-[1.02] hover:shadow-md"
        >
          {ctaText}
        </a>
      </div>
      <div class="overflow-hidden rounded-2xl">
        <img
          src={image}
          alt={imageAlt}
          width="800"
          height="600"
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </div>
    </div>
  </div>
</section>
