---
import Card from "./Card.astro";

interface CardData {
  title: string;
  description: string;
  icon: string;
}

interface Props {
  heading: string;
  intro?: string;
  cards: CardData[];
  columns?: 2 | 3 | 4;
}

const { heading, intro, cards, columns = 4 } = Astro.props;
const colClass = { 2: "sm:grid-cols-2", 3: "sm:grid-cols-2 lg:grid-cols-3", 4: "sm:grid-cols-2 lg:grid-cols-4" }[columns];
---

<section class="border-y border-sand-light bg-paper py-14">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="font-display text-2xl text-ink sm:text-3xl">{heading}</h2>
      {intro && <p class="mt-3 text-ink/70">{intro}</p>}
    </div>
    <div class:list={["mt-10 grid grid-cols-1 gap-6", colClass]}>
      {cards.map((card) => (
        <Card title={card.title} description={card.description} icon={card.icon} />
      ))}
    </div>
  </div>
</section>
