---
// Uses the GoingMorocco PNG logo (1774×887px).
// Aspect ratio is preserved automatically.
//
// Default size:
// - Header: 48px tall
// - Footer: pass height={36} (or another value) when using the component.

interface Props {
  height?: number;
  class?: string;
}

const { height = 48, class: className = "" } = Astro.props;

// Preserve the original aspect ratio (1774 ÷ 887)
const width = Math.round(height * (1774 / 887));
---

<img
  src="/logo.png"
  alt="GoingMorocco.com"
  width={width}
  height={height}
  class={className}
  loading="eager"
  decoding="async"
  style="object-fit: contain;"
/>
