---
// Uses the GoingMorocco PNG logo (1774×887px).
// The aspect ratio is preserved automatically.

interface Props {
  height?: number;
  class?: string;
}

const { height = 48, class: className = "" } = Astro.props;

// Calculate width using the original logo aspect ratio
const width = Math.round(height * (1774 / 887));
---

<img
  src="/logo.png"
  alt="GoingMorocco.com"
  width={width}
  height={height}
  class={className}
  loading="eager"
  decoding="async"
  style="object-fit: contain;"
/>
