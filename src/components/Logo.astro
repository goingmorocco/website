---
// Uses the real GoingMorocco PNG logo (public/logo.png).
// The original is 1774×887px. We display it at a controlled height
// and let width scale proportionally (aspect ratio 2:1).
// header: height 36px → width ~72px  (crisp on retina via srcset/2x)
// footer: height 32px → width ~64px
interface Props {
  height?: number;
  class?: string;
}
const { height = 36, class: className = "" } = Astro.props;
const width = Math.round(height * 2); // 1774/887 ≈ 2:1
---
<img
  src="/logo.png"
  alt="GoingMorocco.com"
  width={width}
  height={height}
  class={className}
  loading="eager"
  decoding="async"
  style="object-fit: contain;"
/>
