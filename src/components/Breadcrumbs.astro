---
interface Crumb {
  label: string;
  href?: string; // omit on the current/last item
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm">
  <ol class="flex flex-wrap items-center gap-2 text-ink/60">
    {
      items.map((item, i) => (
        <li class="flex items-center gap-2">
          {i > 0 && <span aria-hidden="true">/</span>}
          {item.href ? (
            <a href={item.href} class="hover:text-royal">
              {item.label}
            </a>
          ) : (
            <span aria-current="page" class="text-ink">
              {item.label}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
