
---
import Container from "./Container.astro";
import Logo from "./Logo.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import SearchBox from "./SearchBox.astro";
import { t, localizedPath, type Locale } from "../utils/i18n";

interface Props {
  locale: Locale;
  alternateUrls: Partial<Record<Locale, string>>;
}
const { locale, alternateUrls } = Astro.props;
const strings = t(locale);

const navItems = [
  { href: localizedPath(locale, "/"), label: strings.nav.home },
  { href: localizedPath(locale, "/about/"), label: strings.nav.about },
  { href: localizedPath(locale, "/post/"), label: strings.nav.blog },
  { href: localizedPath(locale, "/categories/"), label: strings.nav.categories },
  // External subdomains — not part of Astro's i18n routing, so plain
  // absolute URLs rather than localizedPath().
  { href: "https://booking.goingmorocco.com", label: strings.nav.flights, external: true },
  { href: "https://planner.goingmorocco.com", label: strings.nav.itineraries, external: true },
  { href: localizedPath(locale, "/contact/"), label: strings.nav.contact },
];
---

<header class="sticky top-0 z-50 border-b border-sand-light bg-paper/90 backdrop-blur-sm">
  <Container class="flex items-center justify-between gap-4 py-3">
    <!-- Logo -->
    <a href={localizedPath(locale, "/")} class="flex-shrink-0 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-royal" aria-label="GoingMorocco home">
      <Logo height={208} />
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Main navigation" class="hidden items-center gap-5 lg:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          target={item.external ? "_blank" : undefined}
          rel={item.external ? "noopener" : undefined}
          class="text-sm font-medium text-ink/80 transition-colors hover:text-royal focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-royal"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Desktop: Search + language switcher -->
    <div class="hidden items-center gap-3 lg:flex">
      <SearchBox
        locale={locale}
        placeholder={strings.search.placeholder}
        noResults={strings.search.noResults}
        label={strings.search.label}
        instanceId="desktop"
      />
      <LanguageSwitcher currentLocale={locale} alternateUrls={alternateUrls} />
    </div>

    <!-- Mobile: hamburger -->
    <button
      type="button"
      data-menu-trigger
      aria-expanded="false"
      aria-controls="mobile-nav"
      class="inline-flex h-10 w-10 items-center justify-center rounded-md text-ink focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-royal lg:hidden"
    >
      <span class="sr-only">Open menu</span>
      <svg data-menu-icon-open width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <path d="M3 6h16M3 11h16M3 16h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
      <svg data-menu-icon-close width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true" class="hidden">
        <path d="M5 5l12 12M17 5L5 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" fill="none"/>
      </svg>
    </button>
  </Container>

  <!-- Mobile nav panel -->
  <nav id="mobile-nav" aria-label="Mobile navigation" class="hidden border-t border-sand-light bg-paper lg:hidden">
    <Container class="flex flex-col gap-1 py-3">
      <!-- Mobile search -->
      <div class="pb-2 pt-1">
        <SearchBox
          locale={locale}
          placeholder={strings.search.placeholder}
          noResults={strings.search.noResults}
          label={strings.search.label}
          instanceId="mobile"
        />
      </div>
      {navItems.map((item) => (
        <a
          href={item.href}
          target={item.external ? "_blank" : undefined}
          rel={item.external ? "noopener" : undefined}
          class="rounded-md px-2 py-2.5 text-base font-medium text-ink/80 hover:bg-sand-light hover:text-ink"
        >
          {item.label}
        </a>
      ))}
      <div class="mt-2 border-t border-sand-light pt-3">
        <LanguageSwitcher currentLocale={locale} alternateUrls={alternateUrls} />
      </div>
    </Container>
  </nav>
</header>

<script>
  const trigger = document.querySelector<HTMLButtonElement>("[data-menu-trigger]");
  const panel = document.getElementById("mobile-nav");
  const iconOpen = document.querySelector("[data-menu-icon-open]");
  const iconClose = document.querySelector("[data-menu-icon-close]");

  function setOpen(open: boolean) {
    if (!trigger || !panel) return;
    trigger.setAttribute("aria-expanded", String(open));
    panel.classList.toggle("hidden", !open);
    iconOpen?.classList.toggle("hidden", open);
    iconClose?.classList.toggle("hidden", !open);
  }

  trigger?.addEventListener("click", () => setOpen(trigger.getAttribute("aria-expanded") !== "true"));
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") setOpen(false); });
  document.addEventListener("click", (e) => {
    if (!panel || !trigger) return;
    if (!panel.contains(e.target as Node) && !trigger.contains(e.target as Node)) setOpen(false);
  });
</script>
