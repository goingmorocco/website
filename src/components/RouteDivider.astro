---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<div class:list={["flex items-center gap-3", className]} role="presentation" aria-hidden="true">
  <span class="h-px flex-1 bg-sand-dark/30"></span>
  <span class="h-1.5 w-1.5 rounded-full bg-sand-dark"></span>
  <span class="h-px flex-1 bg-sand-dark/30"></span>
</div>
