---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import RouteDivider from "../../components/RouteDivider.astro";
import PostCard from "../../components/PostCard.astro";
import AboutMoroccoSection from "../../components/home/AboutMoroccoSection.astro";
import ToolPromoSection from "../../components/home/ToolPromoSection.astro";
import FAQSection from "../../components/home/FAQSection.astro";
import { getCollection } from "astro:content";
import { getReadingTime } from "../../utils/reading-time";
import { buildOrganizationSchema } from "../../utils/seo";
import { t } from "../../utils/i18n";

const locale = "ar" as const;
const strings = t(locale);
const posts = await getCollection("blog", (p) => p.data.locale === locale && !p.data.draft);
const categories = await getCollection("categories", (c) => c.data.locale === locale);
const categoryName = (id: string) => categories.find((c) => c.data.id === id)?.data.name;

for (const post of posts) {
  post.data.readingTimeMinutes ??= getReadingTime(post.body ?? "", locale);
}

const featured = posts.filter((p) => p.data.featured).slice(0, 6);
const latest = posts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()).slice(0, 6);
const display = featured.length >= 3 ? featured : latest;
---

<BaseLayout
  locale={locale}
  title="غوينغ موروكو — ذاهب للمغرب؟ إكتشفه أولا!"
  description="أدلة سفر عملية ومكتوبة محلياً عن المغرب: الصحراء، جبال الأطلس، المدن العتيقة، وكيف تخطط رحلة تناسب وقتك وميزانيتك فعلاً."
  alternateUrls={{ en: "/", ar: "/ar/" }}
  structuredData={buildOrganizationSchema(locale)}
>
  <section class="border-b border-sand-light bg-gradient-to-b from-sand-light/50 to-paper py-16 sm:py-24">
    <Container class="max-w-3xl text-center">
      <h1 class="font-display text-4xl leading-tight text-ink sm:text-5xl">
        ذاهب للمغرب؟ إكتشفه أولا!
      </h1>
      <p class="mt-5 text-lg text-ink/70">
        أدلة عملية ومباشرة عن الصحراء وجبال الأطلس والمدن العتيقة — مكتوبة من مراكش، لا منقولة من قائمة عامة.
      </p>
    </Container>
  </section>

  <AboutMoroccoSection locale="ar" />

  <ToolPromoSection
    eyebrow="الرحلات الجوية"
    title="ابحث عن رحلتك إلى المغرب"
    description="قارن رحلات الطيران إلى مراكش والدار البيضاء وفاس وغيرها في بحث واحد. أداة الرحلات لدينا تجلب أسعاراً حقيقية من شركات الطيران لتجد أفضل صفقة وتحجز بثقة."
    ctaText="ابحث عن رحلات"
    ctaHref="https://booking.goingmorocco.com"
    image="/images/home/flights.jpg"
    imageAlt="طائرة تحلق في سماء صافية فوق المغرب"
  />

  <section class="py-16">
    <Container>
      <div class="flex items-baseline justify-between">
        <h2 class="font-display text-2xl text-ink">{strings.home.latestPosts}</h2>
        <a href="/ar/post/" class="text-sm font-medium text-royal hover:underline">{strings.home.viewAll}</a>
      </div>
      <RouteDivider class="my-6" />
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {display.map((post) => (
          <PostCard post={post} categoryName={categoryName(post.data.category)} />
        ))}
      </div>
      <div class="mt-10 text-center">
        <a
          href="/ar/post/"
          class="inline-flex items-center justify-center rounded-full border border-royal px-6 py-3 font-semibold text-royal transition-colors hover:bg-royal hover:text-white"
        >
          المزيد من المقالات
        </a>
      </div>
    </Container>
  </section>

  <ToolPromoSection
    eyebrow="مخطط الرحلات"
    title="دع الذكاء الاصطناعي يخطط رحلتك"
    description="أخبر مخطط الذكاء الاصطناعي لدينا بعدد أيامك وميزانيتك وما تحب — الصحراء أو الجبال أو المدن أو الثلاثة معاً — واحصل على خطة رحلة جاهزة للمغرب خلال دقائق."
    ctaText="خطط رحلتي"
    ctaHref="https://planner.goingmorocco.com"
    image="/images/home/itinerary.jpg"
    imageAlt="خريطة ودفتر تخطيط لرحلة إلى المغرب"
    reverse
  />

  <FAQSection locale="ar" />
</BaseLayout>
