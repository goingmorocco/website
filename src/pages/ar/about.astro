---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import RouteDivider from "../../components/RouteDivider.astro";
import { buildBreadcrumbSchema, type BreadcrumbItem } from "../../utils/seo";
import Breadcrumbs from "../../components/Breadcrumbs.astro";

const locale = "ar" as const;

const breadcrumbItems: BreadcrumbItem[] = [
  { label: "الرئيسية", href: "/ar/" },
  { label: "من نحن" },
];
---

<BaseLayout
  locale={locale}
  title="من نحن — غوينغ موروكو"
  description="غوينغ موروكو هو مكان للمسافرين للتعرف على المغرب، من شخص مغربي أصلي — معلومات صادقة، بلا فخاخ سياحية وبلا تجميل للحقيقة."
  alternateUrls={{ en: "/about/", ar: "/ar/about/" }}
  structuredData={buildBreadcrumbSchema(breadcrumbItems)}
>
  <Container class="py-12">
    <Breadcrumbs items={breadcrumbItems} />
  </Container>

  <Container class="max-w-2xl pb-20">
    <h1 class="font-display text-3xl text-ink sm:text-4xl">من نحن — غوينغ موروكو</h1>
    <RouteDivider class="my-6" />

    <div class="prose-content max-w-none">
      <p>غوينغ موروكو هو مكان للمسافرين للتعرف على المغرب، مباشرة من شخص مغربي أصلي.</p>
      <p>
        هنا ستجد معلومات حقيقية وصادقة عن ما يقدمه هذا البلد الواقع في شمال إفريقيا. بلا فخاخ سياحية، بلا وعود
        كاذبة، وبلا تجميل للحقيقة.
      </p>
      <p>
        كما هو حال كل بلد، للمغرب نقاط قوته وتحدياته. نتحدث عن الجانبين: الأشياء الجيدة التي ستستمتع بها،
        والأشياء التي قد ترغب في تجنبها. هدفنا بسيط: مساعدتك على الحصول على أفضل تجربة ممكنة خلال زيارتك.
      </p>
      <p>
        نعتقد أن المغرب يقدم أكثر بكثير من الجوانب الإيجابية، ونحن واثقون أنك ستحبه هنا بمجرد أن تعرف كيف
        تستفيد أكثر من رحلتك.
      </p>

      <h2>ماذا نقدم</h2>

      <h3>1. المعرفة</h3>
      <p>
        نؤمن أن المعرفة قوة، وهذا ما نشاركه تماماً. تمنحك مقالات مدونتنا معلومات مفيدة للاستعداد لرحلتك،
        بالإضافة إلى نصائح وحيل للبقاء بأمان، وتوفير المال، والاستمتاع أكثر. يمكنك استخدام أدلتنا للتخطيط لرحلتك
        بناءً على اهتماماتك، أو ببساطة القراءة للاستلهام لرحلتك القادمة.
      </p>
      <p>سواء كنت تستكشف المدن، أو الجبال، أو الصحراء، سنكون هنا لمساعدتك على معرفة المزيد عن المغرب.</p>

      <h3>2. الاستشارة</h3>
      <p>
        على الرغم من أنها ليست خدمتنا الأساسية حالياً، إلا أننا نقدم نصائح سفر مجانية. يمكنك التواصل معنا عبر
        <a href="/ar/contact/">صفحة التواصل</a> أو على وسائل التواصل الاجتماعي، وسنبذل قصارى جهدنا للإجابة عن
        أسئلتك ومساعدتك في التخطيط.
      </p>
      <p>
        نربط أيضاً المسافرين بمزودي خدمات محليين موثوقين لتستمتع بضيافة رائعة من أشخاص نعرفهم ونوصي بهم. كل شيء
        يبدأ بمحادثة — تواصل معنا عبر النموذج، أو راسلنا على إنستغرام أو إكس أو فيسبوك. تيك توك ويوتيوب قريباً.
      </p>

      <h3>3. المتجر</h3>
      <p>
        يعمل غوينغ موروكو أيضاً على إطلاق متجر ستتمكن فيه من شراء السجاد ومنتجات مغربية أخرى — كل قطعة مختارة
        بعناية لتقدم لك حرفية مغربية أصيلة، من السجاد اليدوي الجميل إلى الهدايا التذكارية الفريدة وأدلة السفر
        الرقمية. هذا القسم في الطريق، تابعونا قريباً.
      </p>

      <p class="text-sm text-ink/60">
        <strong>تنويه:</strong> نصائحنا وتوصياتنا للسفر تعتمد على تجربة شخصية وأبحاث. قد تتغير الظروف في المغرب،
        لذا تأكد دائماً من التفاصيل المهمة قبل السفر.
      </p>
    </div>
  </Container>
</BaseLayout>
