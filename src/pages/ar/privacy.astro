---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import { buildBreadcrumbSchema, type BreadcrumbItem } from "../../utils/seo";
import Breadcrumbs from "../../components/Breadcrumbs.astro";

const locale = "ar" as const;
const lastUpdated = "29 يونيو 2026";

const breadcrumbItems: BreadcrumbItem[] = [
  { label: "الرئيسية", href: "/ar/" },
  { label: "سياسة الخصوصية" },
];
---

<BaseLayout
  locale={locale}
  title="سياسة الخصوصية — غوينغ موروكو"
  description="كيف يجمع غوينغ موروكو المعلومات ويستخدمها: نموذج التواصل، التحليلات، الروابط التابعة، والإعلانات."
  alternateUrls={{ en: "/privacy/", ar: "/ar/privacy/" }}
  structuredData={buildBreadcrumbSchema(breadcrumbItems)}
>
  <Container class="py-12">
    <Breadcrumbs items={breadcrumbItems} />
  </Container>

  <Container class="max-w-2xl pb-20">
    <h1 class="font-display text-3xl text-ink sm:text-4xl">سياسة الخصوصية</h1>
    <p class="mt-2 text-sm text-ink/60">آخر تحديث: {lastUpdated}</p>

    <div class="prose-content mt-8 max-w-none">
      <p>
        توضح هذه الصفحة المعلومات التي يجمعها موقع غوينغ موروكو ("نحن") عند زيارتك له، وكيفية استخدامها،
        والخيارات المتاحة لك. نحافظ على البساطة عمداً: لا نُدير حسابات للمستخدمين، ولا نبيع بياناتك الشخصية.
      </p>

      <h2>المعلومات التي نجمعها</h2>
      <p>نجمع المعلومات بثلاث طرق:</p>
      <ul>
        <li>
          <strong>معلومات تقدمها لنا مباشرة</strong> — إذا استخدمت نموذج التواصل أو راسلتنا عبر البريد
          الإلكتروني، نستلم اسمك وبريدك الإلكتروني وما تكتبه لنا. إذا اشتريت من متجرنا (عند توفره)، نجمع اسمك
          وعنوان الشحن وتفاصيل الطلب؛ تتم معالجة الدفع من قبل مزود دفع خارجي (مثل PayPal)، ولا نخزن بيانات
          بطاقتك ولا نصل إليها بعد تأكيد الدفع.
        </li>
        <li>
          <strong>بيانات استخدام تُجمع تلقائياً</strong> — كمعظم المواقع، نستخدم أدوات تحليلات تسجل أموراً مثل
          الصفحات المُزارة، والوقت المستغرق، والموقع التقريبي (على مستوى المدينة/البلد، من عنوان IP)، ونوع
          المتصفح والجهاز. نستخدم هذا لفهم أي الأدلة مفيدة وإصلاح ما لا يعمل بشكل صحيح.
        </li>
        <li><strong>ملفات تعريف الارتباط من أطراف ثالثة</strong> — انظر أدناه.</li>
      </ul>

      <h2>الروابط التابعة (Affiliate)</h2>
      <p>
        تتضمن كثير من أدلة السفر روابط لجولات وفنادق وخدمات أخرى عبر شركاء تابعين (مثل Booking.com و
        GetYourGuide و Travelpayouts). إذا نقرت على أحد هذه الروابط وأكملت حجزاً، قد نحصل على عمولة دون أي
        تكلفة إضافية عليك. لا نرى تفاصيل دفعك، وتحكم سياسة خصوصية كل شريك كيفية تعامله مع بياناتك بعد انتقالك
        إلى موقعه.
      </p>

      <h2>الإعلانات</h2>
      <p>
        نعرض إعلانات عبر Google AdSense. قد تستخدم Google ملفات تعريف الارتباط لعرض إعلانات بناءً على زياراتك
        لهذا الموقع وغيره. يمكنك معرفة المزيد أو إلغاء الإعلانات المخصصة عبر
        <a href="https://adssettings.google.com" target="_blank" rel="noopener noreferrer">adssettings.google.com</a>،
        وقراءة سياسة Google نفسها على
        <a href="https://policies.google.com/technologies/ads" target="_blank" rel="noopener noreferrer">policies.google.com/technologies/ads</a>.
      </p>

      <h2>ملفات تعريف الارتباط (Cookies)</h2>
      <p>
        ملفات تعريف الارتباط هي ملفات صغيرة تُخزَّن على جهازك. نستخدم مجموعة محدودة منها: ما يلزم لعمل الموقع،
        وما يضعه شركاؤنا في التحليلات والإعلانات كما هو موضح أعلاه. يمكنك حظر أو حذف ملفات تعريف الارتباط من
        إعدادات متصفحك؛ قد يؤثر ذلك على عرض بعض الإعلانات أو تذكر تفضيلاتك، لكن المحتوى الأساسي للموقع سيظل
        يعمل.
      </p>

      <h2>مدة الاحتفاظ بالمعلومات</h2>
      <p>
        نحتفظ برسائل نموذج التواصل والبريد الإلكتروني فقط للمدة اللازمة للرد عليك ولفترة معقولة بعد ذلك لسجلاتنا،
        ثم تُحذف. تُحفظ معلومات الطلبات (إذا اشتريت من متجرنا) حسب ما تتطلبه المتطلبات المحاسبية والقانونية.
      </p>

      <h2>حقوقك</h2>
      <p>
        يمكنك أن تطلب منا في أي وقت معرفة المعلومات التي نحتفظ بها عنك، أو تصحيحها، أو حذفها. تواصل معنا عبر
        البريد الإلكتروني أدناه وسنرد في وقت معقول. حسب مكان إقامتك، قد تتمتع بحقوق إضافية بموجب القانون المحلي
        (مثل اللائحة الأوروبية GDPR إذا كنت في الاتحاد الأوروبي أو المملكة المتحدة).
      </p>

      <h2>خصوصية الأطفال</h2>
      <p>
        هذا الموقع غير موجه للأطفال تحت سن 13 عاماً، ولا نجمع معلومات شخصية منهم عن علم. إذا كنت تعتقد أن طفلاً
        قدّم لنا معلومات شخصية، تواصل معنا وسنزيلها.
      </p>

      <h2>تغييرات على هذه السياسة</h2>
      <p>
        قد نُحدّث هذه السياسة من وقت لآخر. يعكس تاريخ "آخر تحديث" أعلى الصفحة أحدث مراجعة. استمرار استخدامك
        للموقع بعد أي تغيير يعني موافقتك على السياسة المحدّثة.
      </p>

      <h2>تواصل معنا</h2>
      <p>
        لديك سؤال حول هذه السياسة؟ راسلنا على <a href="mailto:goingmorocco@gmail.com">goingmorocco@gmail.com</a>
        أو عبر <a href="/ar/contact/">صفحة التواصل</a>.
      </p>

      <p class="text-sm text-ink/60">
        <strong>ملاحظة:</strong> هذه الصفحة مُقدَّمة للشفافية العامة ولا تُعد بديلاً عن المشورة القانونية. إذا
        كنت تدير هذا الموقع كنشاط تجاري في نطاق قضائي له متطلبات محددة (GDPR، CCPA، إلخ)، يُرجى مراجعة هذه
        السياسة من قبل مختص قانوني.
      </p>
    </div>
  </Container>
</BaseLayout>
