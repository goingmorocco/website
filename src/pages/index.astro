---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import RouteDivider from "../components/RouteDivider.astro";
import PostCard from "../components/PostCard.astro";
import AboutMoroccoSection from "../components/home/AboutMoroccoSection.astro";
import DestinationsSection from "../components/home/DestinationsSection.astro";
import PlanYourTripSection from "../components/home/PlanYourTripSection.astro";
import ThingsToDoSection from "../components/home/ThingsToDoSection.astro";
import ItinerariesSection from "../components/home/ItinerariesSection.astro";
import StaySection from "../components/home/StaySection.astro";
import FoodSection from "../components/home/FoodSection.astro";
import TravelTipsSection from "../components/home/TravelTipsSection.astro";
import AboutGoingMoroccoSection from "../components/home/AboutGoingMoroccoSection.astro";
import ToolPromoSection from "../components/home/ToolPromoSection.astro";
import FAQSection from "../components/home/FAQSection.astro";
import Button from "../components/Button.astro";
import { getCollection } from "astro:content";
import { getReadingTime } from "../utils/reading-time";
import { buildOrganizationSchema } from "../utils/seo";
import { t } from "../utils/i18n";

const locale = "en" as const;
const strings = t(locale);
const posts = await getCollection("blog", (p) => p.data.locale === locale && !p.data.draft);
const categories = await getCollection("categories", (c) => c.data.locale === locale);
const categoryName = (id: string) => categories.find((c) => c.data.id === id)?.data.name;

for (const post of posts) {
  post.data.readingTimeMinutes ??= getReadingTime(post.body ?? "", locale);
}

const featured = posts.filter((p) => p.data.featured).slice(0, 6);
const latest = posts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()).slice(0, 6);
const display = featured.length >= 3 ? featured : latest;
---

<BaseLayout
  locale={locale}
  title="Explore Morocco Before Going"
  description="Practical, locally-written Morocco travel guides: the Sahara, the Atlas Mountains, the medinas, and how to plan a trip that actually fits your time and budget."
  alternateUrls={{ en: "/", ar: "/ar/" }}
  structuredData={buildOrganizationSchema(locale)}
>
  <section class="border-b border-sand-light bg-gradient-to-b from-sand-light/50 to-paper py-16 sm:py-24">
    <Container class="max-w-3xl text-center">
      <h1 class="font-display text-4xl leading-tight text-ink sm:text-5xl">
        Going Morocco? Explore it First!
      </h1>
      <p class="mt-5 text-lg text-ink/70">
        Practical, first-hand guides to the Sahara, the Atlas Mountains, and the medinas — written from Marrakech, not assembled from someone else's listicle.
      </p>
    </Container>
  </section>

  <AboutMoroccoSection />

  <DestinationsSection />
  <PlanYourTripSection />
  <ThingsToDoSection />
  <ItinerariesSection />
  <StaySection />
  <FoodSection />
  <TravelTipsSection />
  <AboutGoingMoroccoSection />

  <ToolPromoSection
    eyebrow="Flights"
    title="Find Your Flight to Morocco"
    description="Compare flights to Marrakech, Casablanca, Fez, and beyond in one search. Our flight tool pulls real prices from airlines so you can find the best deal and book with confidence."
    ctaText="Search Flights"
    ctaHref="https://booking.goingmorocco.com"
    image="/images/home/flights.jpg"
    imageAlt="Airplane flying in a clear sky over Morocco"
  />

  <section class="py-16">
    <Container>
      <div class="flex items-baseline justify-between">
        <h2 class="font-display text-2xl text-ink">{strings.home.latestPosts}</h2>
        <a href="/post/" class="text-sm font-medium text-royal hover:underline">{strings.home.viewAll}</a>
      </div>
      <RouteDivider class="my-6" />
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {display.map((post) => (
          <PostCard post={post} categoryName={categoryName(post.data.category)} />
        ))}
      </div>
      <div class="mt-10 text-center">
        <Button href="/post/" variant="outline">View More Posts</Button>
      </div>
    </Container>
  </section>

  <ToolPromoSection
    eyebrow="Itinerary Planner"
    title="Let Our AI Plan Your Trip"
    description="Tell our AI planner how many days you have, your budget, and what you love — deserts, mountains, cities, or all three — and get a ready-made Morocco itinerary in minutes."
    ctaText="Plan My Trip"
    ctaHref="https://planner.goingmorocco.com"
    image="/images/home/itinerary.jpg"
    imageAlt="Map and travel planning notebook for a Morocco trip"
    reverse
  />

  <FAQSection />
</BaseLayout>
