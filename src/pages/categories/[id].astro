---
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import PostCard from "../../components/PostCard.astro";
import { buildBreadcrumbSchema, type BreadcrumbItem } from "../../utils/seo";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { getCollection } from "astro:content";
import { getReadingTime } from "../../utils/reading-time";
import { sortByDateDesc } from "../../utils/posts";

const locale = "en" as const;

export const getStaticPaths = (async () => {
  const categories = await getCollection("categories", (c) => c.data.locale === "en");
  return categories.map((category) => ({ params: { id: category.data.id }, props: { category } }));
}) satisfies GetStaticPaths;

const { category } = Astro.props as Awaited<ReturnType<typeof getStaticPaths>>[number]["props"];

const allPosts = await getCollection("blog", (p) => p.data.locale === locale && !p.data.draft && p.data.category === category.data.id);
const posts = sortByDateDesc(allPosts);
for (const post of posts) {
  post.data.readingTimeMinutes ??= getReadingTime(post.body ?? "", locale);
}

const breadcrumbItems: BreadcrumbItem[] = [
  { label: "Home", href: "/" },
  { label: "Categories", href: "/categories/" },
  { label: category.data.name },
];
---

<BaseLayout
  locale={locale}
  title={`${category.data.name} — GoingMorocco`}
  description={category.data.description}
  alternateUrls={{ en: `/categories/${category.data.id}/` }}
  structuredData={buildBreadcrumbSchema(breadcrumbItems)}
>
  <Container class="py-12">
    <Breadcrumbs items={breadcrumbItems} />
  </Container>

  <Container class="pb-20">
    <h1 class="font-display text-3xl text-ink sm:text-4xl">{category.data.name}</h1>
    <p class="mt-3 max-w-2xl text-ink/70">{category.data.description}</p>

    {
      posts.length > 0 ? (
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => <PostCard post={post} categoryName={category.data.name} />)}
        </div>
      ) : (
        <p class="mt-8 text-ink/60">No guides published in this category yet — check back soon.</p>
      )
    }
  </Container>
</BaseLayout>
