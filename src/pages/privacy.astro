---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import { buildBreadcrumbSchema, type BreadcrumbItem } from "../utils/seo";
import Breadcrumbs from "../components/Breadcrumbs.astro";

const locale = "en" as const;
const lastUpdated = "June 29, 2026";

const breadcrumbItems: BreadcrumbItem[] = [
  { label: "Home", href: "/" },
  { label: "Privacy Policy" },
];
---

<BaseLayout
  locale={locale}
  title="Privacy Policy — GoingMorocco"
  description="How GoingMorocco.com collects and uses information: contact forms, analytics, affiliate links, and advertising."
  alternateUrls={{ en: "/privacy/", ar: "/ar/privacy/" }}
  structuredData={buildBreadcrumbSchema(breadcrumbItems)}
>
  <Container class="py-12">
    <Breadcrumbs items={breadcrumbItems} />
  </Container>

  <Container class="max-w-2xl pb-20">
    <h1 class="font-display text-3xl text-ink sm:text-4xl">Privacy Policy</h1>
    <p class="mt-2 text-sm text-ink/60">Last updated: {lastUpdated}</p>

    <div class="prose-content mt-8 max-w-none">
      <p>
        This page explains what information GoingMorocco.com ("we", "us") collects when you visit, how we use
        it, and the choices you have. We keep this simple on purpose: we don't run user accounts, and we don't
        sell your personal data.
      </p>

      <h2>Information we collect</h2>
      <p>We collect information in three ways:</p>
      <ul>
        <li>
          <strong>Information you give us directly</strong> — if you use our contact form or email us, we
          receive your name, email address, and whatever you write to us. If you purchase from our store
          (when available), we collect your name, shipping address, and order details; payment is processed
          by a third-party processor (such as PayPal), which we do not store or have access to beyond
          confirmation of payment.
        </li>
        <li>
          <strong>Usage data, collected automatically</strong> — like most websites, we use analytics tools
          that record things like pages visited, time on page, approximate location (city/country level, from
          IP address), browser and device type. We use this to understand which guides are useful and to fix
          things that don't work.
        </li>
        <li>
          <strong>Cookies set by third parties</strong> — see below.
        </li>
      </ul>

      <h2>Affiliate links</h2>
      <p>
        Many of our travel guides include links to tours, hotels, and other services through affiliate
        partners (for example Booking.com, GetYourGuide, and Travelpayouts). If you click one of these links
        and make a booking, we may earn a commission at no extra cost to you. These partners may set their own
        cookies to track that a booking came from our site — we don't see your payment details, and each
        partner's own privacy policy governs how they handle your data once you're on their site.
      </p>

      <h2>Advertising</h2>
      <p>
        We display ads through Google AdSense. Google may use cookies to show ads based on your visits to
        this and other sites. You can learn more or opt out of personalized advertising at
        <a href="https://adssettings.google.com" target="_blank" rel="noopener noreferrer">adssettings.google.com</a>,
        and read Google's own policy at
        <a href="https://policies.google.com/technologies/ads" target="_blank" rel="noopener noreferrer">policies.google.com/technologies/ads</a>.
      </p>

      <h2>Cookies</h2>
      <p>
        Cookies are small files stored on your device. We use a minimal set: ones needed for the site to
        function, and ones set by our analytics and advertising partners as described above. You can block or
        delete cookies through your browser settings; doing so may affect how some pages display ads or
        remember your preferences, but the core content of the site will still work.
      </p>

      <h2>How long we keep information</h2>
      <p>
        Contact form messages and emails are kept only as long as needed to respond to you and for a
        reasonable period afterward for our records, then deleted. Order information (if you've purchased
        from our store) is kept as required for accounting and legal purposes.
      </p>

      <h2>Your rights</h2>
      <p>
        You can ask us at any time to tell you what information we hold about you, correct it, or delete it.
        Contact us at the email below and we'll respond within a reasonable time. Depending on where you
        live, you may have additional rights under local law (for example GDPR if you're in the EU/UK).
      </p>

      <h2>Children's privacy</h2>
      <p>
        This site is not directed at children under 13, and we do not knowingly collect personal information
        from them. If you believe a child has provided us with personal information, contact us and we'll
        remove it.
      </p>

      <h2>Changes to this policy</h2>
      <p>
        We may update this policy from time to time. The "Last updated" date at the top will reflect the most
        recent revision. Continued use of the site after a change means you accept the updated policy.
      </p>

      <h2>Contact us</h2>
      <p>
        Questions about this policy? Email us at <a href="mailto:goingmorocco@gmail.com">goingmorocco@gmail.com</a>
        or use our <a href="/contact/">contact page</a>.
      </p>

      <p class="text-sm text-ink/60">
        <strong>Note:</strong> this page is provided for general transparency and is not a substitute for
        legal advice. If you operate this site for a business in a jurisdiction with specific requirements
        (GDPR, CCPA, etc.), have this policy reviewed by a qualified professional.
      </p>
    </div>
  </Container>
</BaseLayout>
