---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import { buildBreadcrumbSchema, type BreadcrumbItem } from "../utils/seo";
import Breadcrumbs from "../components/Breadcrumbs.astro";

const locale = "en" as const;

const breadcrumbItems: BreadcrumbItem[] = [
  { label: "Home", href: "/" },
  { label: "Contact" },
];

const socialLinks = [
  { label: "Instagram", href: "https://www.instagram.com/goingmorocco/" },
  { label: "X", href: "https://x.com/GoingMorocco" },
  { label: "Facebook", href: "https://www.facebook.com/profile.php?id=61561027915599" },
  { label: "Pinterest", href: "https://www.pinterest.com/goingmorocco/" },
];
---

<BaseLayout
  locale={locale}
  title="Contact — GoingMorocco"
  description="Questions about planning a trip to Morocco? Get in touch with GoingMorocco.com."
  alternateUrls={{ en: "/contact/", ar: "/ar/contact/" }}
  structuredData={buildBreadcrumbSchema(breadcrumbItems)}
>
  <Container class="py-12">
    <Breadcrumbs items={breadcrumbItems} />
  </Container>

  <Container class="max-w-2xl pb-20">
    <h1 class="font-display text-3xl text-ink sm:text-4xl">Get in touch</h1>
    <p class="mt-3 text-ink/70">
      Planning a trip and have a question, or want to connect about a partnership? Send a message and we'll
      get back to you — usually within a couple of days.
    </p>

    <!--
      Form-as-a-service pattern: no backend needed for a static site. Sign up
      at formspree.io (or web3forms.com), replace YOUR_FORM_ID below with the
      real endpoint, and this form works with zero JavaScript and zero server.
    -->
    <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="mt-8 space-y-5">
      <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

      <div>
        <label for="name" class="block text-sm font-medium text-ink">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="mt-1.5 w-full rounded-md border border-sand-light bg-white px-3 py-2 text-ink focus:border-royal focus:outline-none focus-visible:ring-2 focus-visible:ring-royal"
        />
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-ink">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="mt-1.5 w-full rounded-md border border-sand-light bg-white px-3 py-2 text-ink focus:border-royal focus:outline-none focus-visible:ring-2 focus-visible:ring-royal"
        />
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-ink">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="mt-1.5 w-full rounded-md border border-sand-light bg-white px-3 py-2 text-ink focus:border-royal focus:outline-none focus-visible:ring-2 focus-visible:ring-royal"
        ></textarea>
      </div>

      <button
        type="submit"
        class="rounded-full bg-royal px-6 py-2.5 text-sm font-semibold text-paper transition-colors hover:bg-royal-dark focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-royal"
      >
        Send message
      </button>
    </form>

    <div class="mt-12 border-t border-sand-light pt-8 text-sm text-ink/70">
      <p>
        Prefer email? Reach us directly at
        <a class="text-royal underline" href="mailto:goingmorocco@gmail.com">goingmorocco@gmail.com</a>.
      </p>
      <p class="mt-3">
        Or find us on
        {socialLinks.map((link, i) => (
          <>
            <a class="text-royal underline" href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
            {i < socialLinks.length - 1 ? " · " : ""}
          </>
        ))}
        .
      </p>
    </div>
  </Container>
</BaseLayout>
